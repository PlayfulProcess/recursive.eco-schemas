    {
      "id": "book04-the-rabbits-house",
      "name": "THE RABBIT'S HOUSE",
      "level": 1,
      "category": "booklet",
      "sort_order": 4,
      "sections": {
        "Page 1": "THE WHITE RABBIT SAW ALICE.\n\"MARY ANN! GO GET MY GLOVES!\"\nALICE WAS NOT MARY ANN.\nBUT SHE WENT TO HIS HOUSE.",
        "Page 2": "IN THE HOUSE, SHE DRANK A BOTTLE.\nSHE GREW SO BIG SHE GOT STUCK!\nHER ARM WENT OUT THE WINDOW.",
        "Page 3": "\"BILL! GO DOWN THE CHIMNEY!\"\nA LITTLE LIZARD CAME DOWN.\nALICE KICKED HIM RIGHT BACK UP!",
        "Page 4": "AT LAST ALICE ATE SOME PEBBLES.\nTHEY WERE REALLY LITTLE CAKES!\nSHE GOT SMALL AND RAN AWAY.\nSHE MET A VERY BIG PUPPY."
      },
