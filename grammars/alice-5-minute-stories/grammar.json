    {
      "id": "book02-the-pool-of-tears",
      "name": "THE POOL OF TEARS",
      "level": 1,
      "category": "booklet",
      "sort_order": 2,
      "sections": {
        "Page 1": "ALICE WAS NOW VERY, VERY TALL.\n\"CURIOUSER AND CURIOUSER!\" SHE SAID.",
        "Page 2": "SHE BEGAN TO CRY BIG TEARS.\nHER TEARS MADE A POOL ON THE FLOOR!",
        "Page 3": "THEN SHE GOT SMALL AGAIN.\nSHE FELL INTO HER OWN POOL OF TEARS!\n\"I WISH I HAD NOT CRIED SO MUCH!\"",
        "Page 4": "A MOUSE WAS SWIMMING IN THE POOL.\n\"EXCUSE ME, DO YOU KNOW THE WAY OUT?\"\nASKED ALICE."
      },
