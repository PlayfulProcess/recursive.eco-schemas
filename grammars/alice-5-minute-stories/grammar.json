    {
      "id": "book03-the-race",
      "name": "THE RACE",
      "level": 1,
      "category": "booklet",
      "sort_order": 3,
      "sections": {
        "Page 1": "ALL THE ANIMALS WERE WET.\n\"WE MUST GET DRY!\" SAID THE MOUSE.\nHE TOLD A VERY BORING STORY.",
        "Page 2": "\"LET US HAVE A RACE!\" SAID THE DODO.\nTHEY ALL RAN IN A BIG CIRCLE.\nROUND AND ROUND AND ROUND.",
        "Page 3": "\"WHO WON?\" ASKED ALICE.\n\"EVERYBODY WON!\" SAID THE DODO.\n\"EVERYBODY GETS A PRIZE!\"",
        "Page 4": "THE MOUSE TOLD A SAD, LONG TALE.\nIT LOOKED LIKE A TAIL ON THE PAGE!\nTHEN THE MOUSE RAN AWAY."
      },
